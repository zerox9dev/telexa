TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
ALLOWED_USER_ID=

# Overridden by docker-compose. Set manually only if running outside Docker.
DATABASE_URL=postgresql+asyncpg://telexa:telexa@localhost:5432/telexa

# Comma-separated origins allowed to call the API.
# In Docker the frontend is served by the same container — leave as-is.
# Add your LAN IP or domain if accessing from other devices.
ALLOWED_ORIGINS=http://localhost:8000
